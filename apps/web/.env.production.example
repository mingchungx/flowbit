# Required
DATABASE_URL=postgres://user:password@host:5432/flowbit

# Private key encryption (required for production)
KEY_ENCRYPTION_SECRET=<generate-a-random-64-char-hex-string>

# On-chain integration (optional)
DEPLOYER_PRIVATE_KEY=
TEST_USDC_ADDRESS=
BASE_SEPOLIA_RPC_URL=

# Logging
LOG_LEVEL=info
